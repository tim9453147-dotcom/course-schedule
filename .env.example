# 複製這個檔案成 .env 再填入自己的值
# 管理員登入帳密
NUXT_ADMIN_USERNAME=admin
NUXT_ADMIN_PASSWORD=change-this-password

# session cookie 加密金鑰，請用至少 32 字元的隨機字串
# 可用指令產生：openssl rand -base64 32
NUXT_SESSION_PASSWORD=please-change-this-to-a-random-32-char-string

# Gemini 圖片辨識匯入（免費方案，到 https://aistudio.google.com 申請 API key）
# 留空則「上傳圖片辨識」會回報尚未設定，手動貼 JSON 匯入不受影響
NUXT_GEMINI_API_KEY=
# 可選，預設 gemini-2.5-flash
# NUXT_GEMINI_MODEL=gemini-2.5-flash

# LINE Messaging API（課表異動通知，見 specs/0025）
# 於 LINE Developers Console 的 channel 取得；留空則 webhook / push 不作用
NUXT_LINE_CHANNEL_ACCESS_TOKEN=
NUXT_LINE_CHANNEL_SECRET=
# 每日彙整通知端點（/api/notifications/daily-digest）的 Bearer 金鑰，GitHub Actions cron 用
# 產生：openssl rand -hex 24
NUXT_NOTIFY_CRON_SECRET=
