{
  "name": "course-schedule",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply course-schedule-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply course-schedule-db --remote",
    "db:seed:local": "wrangler d1 execute course-schedule-db --local --file=./server/db/seed.sql",
    "deploy": "nuxt build && wrangler pages deploy dist --project-name course-schedule-2689336 --branch main"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@iconify-json/lucide": "^1.2.112",
    "@iconify-json/simple-icons": "^1.2.86",
    "@nuxt/ui": "^4.8.2",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.25",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5",
    "wrangler": "4"
  }
}
